# Simple class with constructor and method.

class Duck {
    init(name) {
        self.name = name
    }

    quack() {
        print concat [self.name, "quacks"]
    }
}

class Math {
    square(n) {
        return n * n
    }
}

var duck = Duck "Waddles"
duck.quack()

var math = Math()
print math.square 3
