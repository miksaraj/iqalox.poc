fun describe(n) {
    print concat [n, " is ", (n % 2 == 0) ? "even" : "odd"]
}

describe 4
describe 7

print concat ["2 ^ 10 = ", 2 ^ 10]

var pi = 3.14
print (pi * 2)

var enabled mut = false
print (!enabled)

var fallback = nil ?? "default"
print fallback

# Only `nil` and `false` are falsy -- every other value, including an empty
# string, takes the elvis operator's left branch.
var name mut = false
print (name ?: "anonymous")
name = "Waddles"
print (name ?: "anonymous")
