<#
    Anonymous function literals ("lambdas", 0.2): (a, b) -> expr,
    single-expression body only -- no block body, no return. Distinct
    from the named nested-function closures already supported. See
    docs/PLAN-0.2.md decision 1.
#>

var square = (n) -> n * n
print square 3

var add = (a, b) -> a + b
print add 2, 3

fun applyTwice(f, x) {
    return f (f x)
}

print applyTwice square, 4

# A lambda closes over its defining scope exactly like a named function.
fun makeAdder(n) {
    return (x) -> x + n
}

var add5 = makeAdder 5
print add5 10
